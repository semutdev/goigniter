# --- Database Configuration ---
DB_DRIVER="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="myapp"

# SQLite (uncomment to use)
# DB_DRIVER="sqlite"
# DB_DSN="./app.db"

# --- Application Configuration ---
APP_ENV="local"
APP_PORT=":8080"
APP_URL="http://localhost:8080"
APP_KEY="your-secret-key-32-characters-long"

# --- Database Seeder (set to true once to create tables) ---
DB_SEED="false"
